{
  "version": "4.3.0",
  "platform": "generic",
  "paths": {
    "data_dir": "data",
    "tasks_dir": "${data_dir}/tasks",
    "decisions_dir": "${data_dir}/decisions",
    "risks_dir": "${data_dir}/risks",
    "memory_dir": "${data_dir}/memory",
    "logs_dir": "${data_dir}/logs",
    "agents_dir": "${data_dir}/agents",
    "dashboard_dir": "${data_dir}/dashboard",
    "assignments_dir": "${data_dir}/assignments"
  },
  "storage": {
    "backend": "file",
    "file_lock": true,
    "auto_backup": false
  },
  "features": {
    "readonly_mode": false,
    "auto_sync_memory": true,
    "sla_check_enabled": true,
    "risk_alert_threshold": 3
  },
  "ai_platform": {
    "name": "generic",
    "tool_prefix": "python3 tools/",
    "supports_bash": true,
    "supports_function_calling": false
  },
  "agent_defaults": {
    "model": {
      "source": "platform_default",
      "provider": null,
      "model": null,
      "api_base": null,
      "api_key_env": null,
      "headers": {},
      "temperature": null,
      "max_tokens": null
    }
  },
  "dashboard": {
    "host": "127.0.0.1",
    "port": 8765,
    "refresh_seconds": 8
  },
  "orchestration": {
    "main_agent_id": "ceo"
  },
  "platforms": {
    "claude_code": {
      "skill_path": "~/.claude/skills/opc-team/SKILL.md",
      "tool_prefix": "python3 tools/",
      "supports_bash": true
    },
    "openclaw": {
      "skill_path": "~/.openclaw/workspace-{agent}/skills/opc-team/SKILL.md",
      "tool_prefix": "python3 tools/",
      "supports_bash": true
    },
    "cursor": {
      "skill_path": ".cursorrules",
      "tool_prefix": "",
      "supports_bash": false
    },
    "windsurf": {
      "skill_path": ".windsurfrules",
      "tool_prefix": "",
      "supports_bash": true
    },
    "api": {
      "skill_path": null,
      "tool_prefix": "",
      "supports_function_calling": true
    },
    "generic": {
      "skill_path": null,
      "tool_prefix": "python3 tools/",
      "supports_bash": true
    }
  }
}
