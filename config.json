{
  "version": "4.4.0",
  "platform": "generic",
  "paths": {
    "data_dir": "data",
    "tasks_dir": "${data_dir}/tasks",
    "decisions_dir": "${data_dir}/decisions",
    "risks_dir": "${data_dir}/risks",
    "memory_dir": "${data_dir}/memory",
    "logs_dir": "${data_dir}/logs",
    "agents_dir": "${data_dir}/agents",
    "dashboard_dir": "${data_dir}/dashboard",
    "assignments_dir": "${data_dir}/assignments"
  },
  "storage": {
    "backend": "file",
    "file_lock": true,
    "auto_backup": false
  },
  "features": {
    "readonly_mode": false,
    "auto_sync_memory": true,
    "sla_check_enabled": true,
    "risk_alert_threshold": 3
  },
  "ai_platform": {
    "name": "generic",
    "tool_prefix": "python3 tools/",
    "supports_bash": true,
    "supports_function_calling": false
  },
  "agent_defaults": {
    "model": {
      "source": "platform_default",
      "provider": null,
      "model": null,
      "api_base": null,
      "api_key_env": null,
      "headers": {},
      "temperature": null,
      "max_tokens": null
    }
  },
  "model_catalog": {
    "custom_models": []
  },
  "dashboard": {
    "host": "127.0.0.1",
    "port": 8765,
    "refresh_seconds": 8
  },
  "orchestration": {
    "main_agent_id": "ceo",
    "agent_pack": "default",
    "default_profile": "daily",
    "dispatch_profiles": {
      "daily": {
        "label": "日常常驻",
        "sub_agent_target": 3,
        "agent_ids": [
          "coo",
          "project",
          "strategist"
        ]
      },
      "important": {
        "label": "重要任务",
        "sub_agent_target": 8,
        "agent_ids": [
          "coo",
          "project",
          "strategist",
          "research",
          "product",
          "tech",
          "data",
          "qa"
        ]
      },
      "full": {
        "label": "满编协同",
        "sub_agent_target": 20,
        "agent_ids": "__all_sub_agents__"
      }
    },
    "profile_keywords": {
      "full": [
        "满血",
        "全员",
        "全部代理",
        "所有代理",
        "20个代理",
        "复杂任务",
        "高复杂度",
        "跨部门",
        "集团级",
        "全量",
        "专项战役",
        "用户指定"
      ]
    }
  },
  "platforms": {
    "claude_code": {
      "skill_path": "~/.claude/skills/opc-team/SKILL.md",
      "tool_prefix": "python3 tools/",
      "supports_bash": true
    },
    "openclaw": {
      "skill_path": "~/.openclaw/workspace-{agent}/skills/opc-team/SKILL.md",
      "tool_prefix": "python3 tools/",
      "supports_bash": true
    },
    "cursor": {
      "skill_path": ".cursorrules",
      "tool_prefix": "",
      "supports_bash": false
    },
    "windsurf": {
      "skill_path": ".windsurfrules",
      "tool_prefix": "",
      "supports_bash": true
    },
    "api": {
      "skill_path": null,
      "tool_prefix": "",
      "supports_function_calling": true
    },
    "generic": {
      "skill_path": null,
      "tool_prefix": "python3 tools/",
      "supports_bash": true
    }
  }
}
